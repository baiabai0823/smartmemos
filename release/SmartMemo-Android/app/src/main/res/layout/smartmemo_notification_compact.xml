    <TextView android:id="@+id/reminder_time_card" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:ellipsize="end" android:maxLines="1" android:paddingStart="8dp" android:paddingTop="2dp" android:paddingEnd="8dp" android:paddingBottom="2dp" android:textColor="#39414A" android:textSize="13sp" android:textStyle="bold" />
