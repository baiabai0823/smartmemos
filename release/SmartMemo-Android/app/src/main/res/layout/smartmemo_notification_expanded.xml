<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingStart="12dp" android:paddingTop="10dp" android:paddingEnd="12dp" android:paddingBottom="10dp">
    <TextView android:id="@+id/reminder_title" android:layout_width="match_parent" android:layout_height="wrap_content" android:maxLines="2" android:textColor="#1E2329" android:textSize="17sp" android:textStyle="bold" />
    <TextView android:id="@+id/reminder_time_card" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="7dp" android:paddingStart="11dp" android:paddingTop="8dp" android:paddingEnd="11dp" android:paddingBottom="8dp" android:textColor="#39414A" android:textSize="15sp" android:textStyle="bold" />
    <TextView android:id="@+id/reminder_content" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="7dp" android:textColor="#303740" android:textSize="14sp" android:textStyle="bold" />
    <TextView android:id="@+id/reminder_remark" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="7dp" android:maxLines="3" android:textColor="#737C87" android:textSize="12sp" />
</LinearLayout>